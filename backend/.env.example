# ===========================================
# DealDirect Backend - Environment Variables
# ===========================================
# Copy this file to .env and fill in your values
# NEVER commit .env file to Git!

# Server Configuration
PORT=9000
NODE_ENV=production

# Database (MongoDB Atlas)
MONGO_URI=mongodb+srv://username:password@cluster.mongodb.net/database?retryWrites=true&w=majority

# JWT Secret (Generate a strong 64+ character random string)
# Run: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your-super-secret-jwt-key-at-least-64-characters-long

# Cloudinary Configuration (for image uploads)
CLOUDINARY_URL=cloudinary://api_key:api_secret@cloud_name

# Email Configuration (Gmail SMTP)
SMTP_USER=your-email@gmail.com
SMTP_EMAIL=your-email@gmail.com
SMTP_PASS=your-app-specific-password
SENDER_EMAIL=your-email@gmail.com

# Google Gemini AI API
GEMINI_API_KEY=your-gemini-api-key

# Mapples API Key (for maps)
MAPPLES_API_KEY=your-mapples-api-key

# Agreement Document Secret Key
AGREEMENT_SECRET_KEY=your-agreement-secret-key

# Frontend URLs (Required for CORS in production)
CLIENT_URL=https://dealdirect.in
ADMIN_URL=https://admin.dealdirect.in

# Cookie Domain (for cross-subdomain cookie sharing)
# Use .yourdomain.com (with leading dot) to share cookies across subdomains
COOKIE_DOMAIN=.dealdirect.in

# Optional: Trusted Proxies (comma-separated IPs for production)
# TRUSTED_PROXIES=127.0.0.1,10.0.0.0/8

# Sentry Error Tracking (Backend)
# Get your DSN from https://sentry.io -> Project Settings -> Client Keys (DSN)
SENTRY_DSN=your-sentry-dsn-url

# ============================================
# Equence Technologies SMS Service (api.equence.in)
# API Docs: Equence SMS API Reference Document v1.0
# ============================================
EQUENCE_USERNAME=your-equence-username
EQUENCE_PASSWORD=your-equence-password
EQUENCE_SENDER_ID=DEALDR
EQUENCE_PE_ID=your-dlt-principal-entity-id
EQUENCE_BASE_URL=https://api.equence.in/pushsms

# DLT Template IDs (mandatory for all SMS)
EQUENCE_OTP_TMPL_ID=your-otp-template-id
EQUENCE_RESET_TMPL_ID=your-reset-template-id

# Optional: Payment Webhook Secret
# PAYMENT_WEBHOOK_SECRET=your-webhook-secret

# ============================================
# WAHA WhatsApp API (WhatsApp HTTP API)
# Hosted on Railway — sends WhatsApp notifications
# ============================================
WAHA_API_URL=https://your-instance.up.railway.app
WAHA_API_KEY=your-waha-api-key
WAHA_SESSION=default
WAHA_ADMIN_PHONE=919876543210

# ============================================
# RewardPort Product Catalogue API
# URL: https://catalogue.rewardzpromo.com
# Auth: HTTP Basic Authentication
# ============================================
REWARDPORT_USERNAME=your-rewardport-username
REWARDPORT_PASSWORD=your-rewardport-password

# ============================================
# Hubble Gift Card SDK (myhubble.money)
# Docs: https://docs.myhubble.money
# Dashboard: https://partners.myhubble.money
# ============================================
HUBBLE_CLIENT_ID=your-hubble-client-id
HUBBLE_APP_SECRET=your-hubble-app-secret
# X-Hubble-Secret: auto-generated when you save auth config on Hubble portal
HUBBLE_WEBHOOK_SECRET=your-hubble-webhook-secret
# SDK base URL — MUST match your credentials' environment
# Staging: https://sdk.dev.myhubble.money/
# Production: https://sdk.myhubble.money/
HUBBLE_SDK_BASE_URL=https://sdk.dev.myhubble.money/
# Optional: SDK theme (light or dark)
HUBBLE_THEME=light
